{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "finops-llm",
  "main": "_site/worker.js",
  "compatibility_date": "2026-05-05",
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "npm run build",
    "cwd": ".",
    "watch_dir": "src"
  },
  "assets": {
    "directory": "_site",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
