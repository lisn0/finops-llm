<thead>
<tr>
  <th>コンポーネント</th>
  <th>プロバイダー例</th>
  <th>コスト</th>
  <th>注記</th>
</tr>
</thead>
<tbody>
<tr>
  <td><strong>訓練（10Kサンプル上のLlama 3.3 70B）</strong></td>
  <td>Together AI</td>
  <td class="number">$300</td>
  <td>単一H100 GPU上のLoRA（~4時間）</td>
</tr>
<tr>
  <td><strong>推論（1Mトークンあたり）</strong></td>
  <td>Groq (Llama 3.3 70B)</td>
  <td class="number">$0.27</td>
  <td>高速（ファインチューニング済みGPT-4対調整ラグなし）</td>
</tr>
<tr>
  <td><strong>推論（1Mトークンあたり）</strong></td>
  <td>Together AI (Llama 3.3 70B)</td>
  <td class="number">$0.18</td>
  <td>低速応答、低コスト</td>
</tr>
