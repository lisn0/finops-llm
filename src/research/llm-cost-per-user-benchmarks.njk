  <td class="number">1,000</td>
  <td>DeepSeek V4 Flash</td>
  <td class="number">$35–$50</td>
  <td class="number">$0.21 in / $0.14 out (50% disc)</td>
</tr>
<tr>
  <td><strong>Medium (1M records)</strong></td>
  <td class="number">1,000,000</td>
  <td class="number">1,000</td>
  <td>Gemini Flash + Batch</td>
  <td class="number">$300–$450</td>
  <td class="number">$0.75 in / $4.50 out (50% disc)</td>
</tr>
<tr>
  <td><strong>Heavy (10M records)</strong></td>
  <td class="number">10,000,000</td>
  <td class="number">1,000</td>
