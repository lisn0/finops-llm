<thead>
<tr>
  <th>Component</th>
  <th>GPT-4o (Old)</th>
  <th>GPT-5.6 Terra (New)</th>
  <th>Per 1M Calls (avg 1K in / 200 out)</th>
</tr>
</thead>
<tbody>
<tr>
  <td><strong>Input cost per 1M</strong></td>
  <td class="number">$3.00</td>
  <td class="number">$2.50</td>
  <td class="number">–$500</td>
</tr>
<tr>
  <td><strong>Output cost per 1M</strong></td>
  <td class="number">$15.00</td>
  <td class="number">$15.00</td>
  <td class="number">$0</td>
</tr>
<tr class="highlight">
