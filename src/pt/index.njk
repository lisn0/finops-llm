          <path d="M16 22 L16 16 L20 16 L20 22 M16 19 L20 19" stroke="#fff" stroke-width="2" stroke-linecap="square" fill="none"/>
          <circle cx="24" cy="11" r="2" fill="#9BE08D"/>
