  <div class="hero-stat"><span class="num">8</span><span class="lbl">Modelos comparados</span></div>
  <div class="hero-stat"><span class="num">5</span><span class="lbl">Níveis de GPU analisados</span></div>
  <div class="hero-stat"><span class="num">3</span><span class="lbl">Cenários de equilíbrio</span></div>
