<script>
(function(){
  var rateSlider=document.getElementById('convRate'),rateDisplay=document.getElementById('convVal'),sortSelect=document.getElementById('sortMode'),table=document.getElementById('planTable'),tbody=table.querySelector('tbody'),headers=table.querySelectorAll('th[data-col]'),toggleBtns=document.querySelectorAll('.toggle-btn');
  rateSlider.addEventListener('input',function(){rateDisplay.textContent=this.value});
  var currentSort={col:null,asc:true};
  headers.forEach(function(th){th.addEventListener('click',function(){var col=this.dataset.col;if(currentSort.col===col){currentSort.asc=!currentSort.asc}else{currentSort.col=col;currentSort.asc=true}headers.forEach(function(h){h.classList.remove('sorted')});this.classList.add('sorted');this.querySelector('.sort-arrow').textContent=currentSort.asc?'↑':'↓';sortTable(col,currentSort.asc)})});
  function sortTable(col,asc){var rows=Array.from(tbody.querySelectorAll('tr'));var colMap={provider:0,plan:1,price:2,promptMo:4,reqMo:5,promptUsd:6,reqUsd:7,intelligence:9,coding:10,agentic:11};var idx=colMap[col];if(idx===undefined)return;rows.sort(function(a,b){var va,vb;if(col==='price'){va=parseFloat(a.cells[idx].textContent.replace(/[^0-9.]/g,''));vb=parseFloat(b.cells[idx].textContent.replace(/[^0-9.]/g,''))}else if(col==='provider'||col==='plan'){va=a.cells[idx].textContent.trim();vb=b.cells[idx].textContent.trim();return asc?va.localeCompare(vb):vb.localeCompare(va)}else{va=parseFloat(a.cells[idx].dataset.val||0);vb=parseFloat(b.cells[idx].dataset.val||0)}return asc?va-vb:vb-va});rows.forEach(function(r){tbody.appendChild(r)})}
  sortSelect.addEventListener('change',function(){var mode=this.value;if(mode==='default')return;var maxPrice=mode==='vfm10'?10:mode==='vfm30'?30:Infinity;var rows=Array.from(tbody.querySelectorAll('tr'));rows.sort(function(a,b){var pa=parseFloat(a.cells[2].textContent.replace(/[^0-9.]/g,''));var pb=parseFloat(b.cells[2].textContent.replace(/[^0-9.]/g,''));var inRangeA=pa<=maxPrice?1:0;var inRangeB=pb<=maxPrice?1:0;if(inRangeA!==inRangeB)return inRangeB-inRangeA;var va=parseFloat(a.cells[7].dataset.val||0);var vb=parseFloat(b.cells[7].dataset.val||0);return vb-va});rows.forEach(function(r){tbody.appendChild(r)})});
  toggleBtns.forEach(function(btn){btn.addEventListener('click',function(){toggleBtns.forEach(function(b){b.classList.remove('active')});this.classList.add('active');var show=this.dataset.show;var rows=tbody.querySelectorAll('tr');rows.forEach(function(r){var uses=r.cells[3].textContent.toLowerCase();if(show==='all')r.style.display='';else if(show==='coding')r.style.display=uses.includes('coding')?'':'none';else if(show==='agent')r.style.display=uses.includes('agent')?'':'none'})})});
})();
</script>
