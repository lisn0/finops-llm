        <!-- MAIN -->
        <div class="ck-main">
          <div class="ck-tabs">
            <span class="ck-tab active">Descripción general</span>
            <span class="ck-tab">Gasto</span>
            <span class="ck-tab">Calidad</span>
            <span class="ck-tab">Conciliación</span>
          </div>

          <div class="kpi-row">
            <div class="kpi">
              <div class="l">Gasto mes a la fecha</div>
              <div class="v">$70,280</div>
              <div class="d">↓ 57.4% vs. línea base</div>
            </div>
            <div class="kpi">
              <div class="l">Ahorro de muestra</div>
              <div class="v green">$94,720</div>
              <div class="d">reconciliado con factura</div>
            </div>
            <div class="kpi">
              <div class="l">Tasa de acierto de caché</div>
              <div class="v">38.1%</div>
              <div class="d">+4.2 pts semana a semana</div>
            </div>
            <div class="kpi">
              <div class="l">Delta de calidad</div>
              <div class="v">+0.2%</div>
              <div class="d">Prueba A/B activa 7 días</div>
            </div>
          </div>

          <!-- chart -->
          <div class="ck-card">
            <div class="ck-card-head">
              <h4>Gasto diario de LLM · últimos 45 días</h4>
              <span class="sub">5 abr — 5 may, 2026</span>
            </div>
            <div class="chart">
              <svg viewBox="0 0 500 140" preserveAspectRatio="none">
                <defs>
                  <linearGradient id="grad-base" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#F26A6A" stop-opacity="0.18"/>
                    <stop offset="100%" stop-color="#F26A6A" stop-opacity="0"/>
