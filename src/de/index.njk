<style>
  :root {
    --bg:        #0A0F1A;
    --bg-2:      #0F1623;
    --bg-3:      #131C2C;
    --bg-4:      #1A2538;
    --rule:      #1E2A3F;
    --rule-2:    #2A3850;
    --fg:        #E6EAF2;
    --fg-2:      #9BA8BE;
    --fg-3:      #647289;
    --accent:    #5A8DFF;   /* electric blue */
    --accent-2:  #7AAFFF;
    --accent-soft: rgba(90,141,255,0.12);
    --green:     #4CC38A;
    --green-soft:rgba(76,195,138,0.14);
    --amber:     #F5B242;
    --amber-soft:rgba(245,178,66,0.14);
    --red:       #F26A6A;
    --red-soft:  rgba(242,106,106,0.14);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--bg);
    color: var(--fg);
    font-family: 'Inter', -apple-system, system-ui, sans-serif;
    font-feature-settings: "ss01", "cv11";
    font-size: 16px;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
  .serif { font-family: 'Instrument Serif', Georgia, serif; }
  .mono  { font-family: 'JetBrains Mono', ui-monospace, monospace; font-variant-numeric: tabular-nums; }
  a { color: var(--accent); text-decoration: none; }
  a:hover { color: var(--accent-2); }
  ::selection { background: var(--accent); color: #fff; }

  .skip { position: absolute; top: -50px; left: 12px; background: var(--accent); color: #fff; padding: 10px 14px; font-weight: 600; z-index: 999; }
  .skip:focus { top: 12px; }

  .wrap { max-width: 1320px; margin: 0 auto; padding: 0 32px; }

  /* ============== HEADER ============== */
  header.site {
    position: sticky; top: 0; z-index: 40;
    background: rgba(10,15,26,0.85);
    backdrop-filter: saturate(150%) blur(14px);
    border-bottom: 1px solid var(--rule);
  }
  .nav { display: flex; align-items: center; gap: 36px; padding: 16px 0; }
  .brand { display: flex; align-items: center; gap: 12px; color: var(--fg); }
  .brand:hover { text-decoration: none; }
  .logo-svg { width: 28px; height: 28px; flex-shrink: 0; }
  .brand-name {
    font-size: 18px; font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--fg);
  }
  .brand-name .dim { color: var(--fg-3); font-weight: 500; }
  nav.primary { display: flex; gap: 6px; flex: 1; }
  nav.primary a {
    color: var(--fg-2); font-size: 14px; font-weight: 500;
    padding: 6px 12px; border-radius: 6px;
  }
  nav.primary a:hover { color: var(--fg); background: var(--bg-3); }
  .nav-right { display: flex; align-items: center; gap: 12px; }
  .nav-right .signin { color: var(--fg-2); font-size: 14px; font-weight: 500; padding: 6px 10px; }
  .nav-right .signin:hover { color: var(--fg); }
  .cta-top {
    background: var(--accent); color: #fff;
    padding: 9px 16px;
    font-weight: 600; font-size: 14px;
    border-radius: 8px;
    display: inline-flex; align-items: center; gap: 6px;
    box-shadow: 0 1px 0 rgba(255,255,255,0.15) inset, 0 4px 16px -4px rgba(90,141,255,0.4);
  }
  .cta-top:hover { background: var(--accent-2); color: #fff; }

  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 22px;
    font-weight: 600; font-size: 15px;
    text-decoration: none; cursor: pointer;
    border: 1px solid transparent;
    border-radius: 10px;
    transition: all .15s;
  }
  .btn-primary { background: var(--accent); color: #fff; border-color: var(--accent); box-shadow: 0 1px 0 rgba(255,255,255,0.15) inset, 0 12px 28px -10px rgba(90,141,255,0.5); }
  .btn-primary:hover { background: var(--accent-2); border-color: var(--accent-2); color: #fff; }
  .btn-ghost { background: transparent; color: var(--fg); border-color: var(--rule-2); }
  .btn-ghost:hover { border-color: var(--fg-3); }

  /* ============== HERO ============== */
  .hero {
    padding: 80px 0 24px;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: "";
    position: absolute;
    top: -200px; left: 50%;
    width: 1200px; height: 700px;
    transform: translateX(-50%);
    background: radial-gradient(ellipse at center, rgba(90,141,255,0.18) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }
  .hero .wrap { position: relative; z-index: 1; }

  .hero-top { text-align: center; max-width: 920px; margin: 0 auto 48px; }
  .pill {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 6px 12px 6px 6px;
    background: var(--bg-3);
    border: 1px solid var(--rule);
    border-radius: 999px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--fg-2);
  }
  .pill .v { background: var(--accent-soft); color: var(--accent-2); padding: 3px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; letter-spacing: 0.02em; }
  .pill .arrow { color: var(--fg-3); }
  h1.hero-title {
    font-family: 'Inter', sans-serif;
    font-weight: 800;
    font-size: clamp(48px, 6.4vw, 88px);
    line-height: 1.0;
    letter-spacing: -0.045em;
    color: var(--fg);
    margin: 22px 0 22px;
  }
  h1.hero-title em {
    font-family: 'Instrument Serif', serif;
    font-style: italic;
    font-weight: 400;
    color: var(--accent-2);
    letter-spacing: -0.03em;
  }
  .hero-lead {
    font-size: 20px; line-height: 1.55;
    color: var(--fg-2);
    max-width: 64ch;
    margin: 0 auto 28px;
  }
  .hero-lead strong { color: var(--fg); font-weight: 600; }
  .hero-cta { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; align-items: center; }
  .hero-meta {
    margin-top: 22px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; color: var(--fg-3);
    letter-spacing: 0.04em;
    display: flex; gap: 24px; justify-content: center; flex-wrap: wrap;
  }
  .hero-meta span::before { content: "● "; color: var(--green); margin-right: 4px; }

  /* ============== DASHBOARD ============== */
  .cockpit {
    background: var(--bg-2);
    border: 1px solid var(--rule);
    border-radius: 16px;
    overflow: hidden;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.04) inset,
      0 60px 100px -40px rgba(0,0,0,0.7),
      0 30px 60px -30px rgba(90,141,255,0.15);
  }
  .cockpit-bar {
    display: flex; align-items: center; gap: 14px;
    padding: 12px 18px;
    background: var(--bg-3);
    border-bottom: 1px solid var(--rule);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--fg-2);
  }
  .cockpit-bar .dots { display: flex; gap: 6px; }
  .cockpit-bar .dot { width: 11px; height: 11px; border-radius: 50%; background: var(--rule-2); }
  .cockpit-bar .dot:nth-child(1) { background: #F26A6A; }
  .cockpit-bar .dot:nth-child(2) { background: #F5B242; }
  .cockpit-bar .dot:nth-child(3) { background: #4CC38A; }
  .cockpit-bar .url {
    flex: 1; text-align: center;
    color: var(--fg-3);
    background: var(--bg);
    border: 1px solid var(--rule);
    padding: 5px 14px;
    border-radius: 6px;
    font-size: 12px;
    max-width: 480px;
    margin: 0 auto;
  }
  .cockpit-bar .url::before { content: "🔒  "; opacity: 0.6; }
  .cockpit-bar .live {
    display: inline-flex; align-items: center; gap: 6px;
    color: var(--green);
  }
  .cockpit-bar .live .ld { width: 6px; height: 6px; background: var(--green); border-radius: 50%; animation: pulse 1.6s infinite; }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }

  .cockpit-grid {
    display: grid;
    grid-template-columns: 220px 1fr 320px;
    grid-template-rows: auto 1fr;
    min-height: 540px;
  }

  /* sidebar */
  .ck-side {
    background: var(--bg-2);
    border-right: 1px solid var(--rule);
    padding: 18px 0;
    grid-row: 1 / span 2;
  }
  .ck-side h6 {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--fg-3);
    padding: 10px 18px 6px;
    margin-top: 10px;
  }
  .ck-side h6:first-child { margin-top: 0; }
  .ck-side .it {
    display: flex; align-items: center; gap: 10px;
    padding: 7px 18px;
    font-size: 13.5px;
    color: var(--fg-2);
    cursor: default;
    border-left: 2px solid transparent;
  }
  .ck-side .it.active { color: var(--fg); background: var(--accent-soft); border-left-color: var(--accent); font-weight: 500; }
  .ck-side .it:hover:not(.active) { color: var(--fg); }
  .ck-side .it .i { width: 16px; opacity: 0.8; }
  .ck-side .it .b { margin-left: auto; font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--fg-3); background: var(--bg-3); padding: 1px 6px; border-radius: 4px; }

  /* main content */
  .ck-main {
    padding: 22px 24px;
    grid-column: 2;
    overflow: hidden;
  }
  .ck-tabs {
    display: flex; gap: 22px;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 20px;
  }
  .ck-tab {
    padding: 8px 0 12px;
    font-size: 13.5px; font-weight: 500;
    color: var(--fg-2);
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
  }
  .ck-tab.active { color: var(--fg); border-bottom-color: var(--accent); }

  .kpi-row {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px;
    margin-bottom: 20px;
  }
  .kpi {
    background: var(--bg-3);
    border: 1px solid var(--rule);
    border-radius: 10px;
    padding: 14px 16px;
  }
  .kpi .l {
    font-size: 11px; color: var(--fg-3);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .kpi .v {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 24px;
    color: var(--fg);
    margin-top: 4px;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }
  .kpi .v.green { color: var(--green); }
  .kpi .d {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--green);
    margin-top: 2px;
  }
  .kpi .d.red { color: var(--red); }
  .kpi .d.amb { color: var(--amber); }

  .ck-card {
    background: var(--bg-3);
    border: 1px solid var(--rule);
    border-radius: 10px;
    padding: 18px;
    margin-bottom: 14px;
  }
  .ck-card-head {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 14px;
  }
  .ck-card-head h4 {
    font-size: 14px; font-weight: 600;
    color: var(--fg);
    letter-spacing: -0.015em;
  }
  .ck-card-head .sub {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--fg-3);
  }

  /* spend chart */
  .chart {
    height: 140px;
    position: relative;
    margin-bottom: 8px;
  }
  .chart svg { width: 100%; height: 100%; overflow: visible; }
  .chart-legend {
    display: flex; gap: 18px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--fg-3);
    border-top: 1px solid var(--rule);
    padding-top: 10px;
    margin-top: 8px;
  }
  .chart-legend .lg { display: inline-flex; align-items: center; gap: 6px; }
  .chart-legend .lg .sw { width: 10px; height: 2px; }

  /* attribution bar */
  .attrib {
    display: flex;
    height: 32px;
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: 8px;
    border: 1px solid var(--rule);
  }
  .attrib .seg {
    display: flex; align-items: center; justify-content: center;
    color: #fff;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; font-weight: 600;
  }
  .attrib-key {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 6px 16px;
    margin-top: 10px;
  }
  .attrib-key .k {
    display: flex; align-items: center; gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--fg-2);
  }
  .attrib-key .k .sw { width: 10px; height: 10px; border-radius: 2px; }
  .attrib-key .k .v { margin-left: auto; color: var(--fg); font-weight: 500; }

  /* right rail */
  .ck-rail {
    background: var(--bg-2);
    border-left: 1px solid var(--rule);
    padding: 22px 22px;
    grid-column: 3;
    grid-row: 1 / span 2;
    overflow: hidden;
  }
  .ck-rail h5 {
    font-size: 13px; font-weight: 600; color: var(--fg);
    margin-bottom: 4px;
    letter-spacing: -0.015em;
  }
  .ck-rail .helper {
    font-size: 12px; color: var(--fg-3);
    margin-bottom: 16px;
  }
  .alert {
    display: grid; grid-template-columns: 28px 1fr;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid var(--rule);
  }
  .alert:last-child { border-bottom: none; }
  .alert .i {
    width: 26px; height: 26px;
    border-radius: 7px;
    display: flex; align-items: center; justify-content: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px; font-weight: 700;
    flex-shrink: 0;
  }
  .alert .i.red { background: var(--red-soft); color: var(--red); }
  .alert .i.amb { background: var(--amber-soft); color: var(--amber); }
  .alert .i.grn { background: var(--green-soft); color: var(--green); }
  .alert .i.blu { background: var(--accent-soft); color: var(--accent-2); }
  .alert .ti { font-size: 13px; font-weight: 500; color: var(--fg); margin-bottom: 2px; line-height: 1.35; }
  .alert .meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px; color: var(--fg-3);
    letter-spacing: 0.02em;
  }

  /* logo strip */
  .logos {
    padding: 56px 0 16px;
    text-align: center;
  }
  .logos-head {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--fg-3); margin-bottom: 22px;
  }
  .logos-row {
    display: flex; justify-content: center; align-items: center;
    gap: 56px; flex-wrap: wrap;
    color: var(--fg-2);
    font-family: 'Instrument Serif', serif;
    font-style: italic;
    font-size: 22px;
  }

  /* ============== SECTION SCAFFOLD ============== */
  section { padding: 120px 0; border-top: 1px solid var(--rule); }
  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; color: var(--accent-2);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 500;
    display: inline-flex; align-items: center; gap: 8px;
    margin-bottom: 16px;
  }
  .eyebrow .num {
    background: var(--accent-soft);
    color: var(--accent-2);
    padding: 2px 8px;
    border-radius: 4px;
    font-weight: 600;
  }
  h2.sec-title {
    font-family: 'Inter', sans-serif;
    font-weight: 800;
    font-size: clamp(40px, 4.6vw, 64px);
    line-height: 1.02;
    letter-spacing: -0.04em;
    color: var(--fg);
    max-width: 22ch;
  }
  h2.sec-title em { font-family: 'Instrument Serif', serif; font-style: italic; font-weight: 400; color: var(--accent-2); }
  .sec-sub {
    font-size: 19px; line-height: 1.6;
    color: var(--fg-2);
    max-width: 60ch;
    margin-top: 18px;
  }
  .sec-head {
    margin-bottom: 64px;
    display: grid; grid-template-columns: 1.4fr 1fr;
    gap: 56px;
    align-items: end;
  }
  .sec-head .right { font-size: 16px; color: var(--fg-2); max-width: 42ch; line-height: 1.65; }

  /* ============== PILLARS ============== */
  .pillars {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .pillar {
    background: var(--bg-2);
    border: 1px solid var(--rule);
    border-radius: 14px;
    padding: 32px;
    position: relative;
    overflow: hidden;
  }
  .pillar::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--accent);
    opacity: 0.7;
  }
  .pillar .idx {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; color: var(--fg-3);
    letter-spacing: 0.04em;
    margin-bottom: 24px;
  }
  .pillar .icon-box {
    width: 44px; height: 44px;
    background: var(--accent-soft);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 20px;
    color: var(--accent-2);
  }
  .pillar h3 {
    font-size: 24px; font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--fg);
    margin-bottom: 10px;
  }
  .pillar p {
    font-size: 15px; color: var(--fg-2);
    line-height: 1.6;
    margin-bottom: 18px;
    max-width: 50ch;
  }
  .pillar ul { list-style: none; padding: 0; }
  .pillar li {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12.5px;
    color: var(--fg-2);
    padding: 6px 0 6px 22px;
    position: relative;
    border-top: 1px solid var(--rule);
  }
  .pillar li::before {
    content: "→";
    position: absolute; left: 0; top: 6px;
    color: var(--accent-2);
    font-weight: 700;
  }

  /* ============== TECHNIQUES ============== */
  .tech-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  .tech-card {
    background: var(--bg-2);
    border: 1px solid var(--rule);
    border-radius: 12px;
    padding: 28px;
    position: relative;
  }
  .tech-card .row {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 18px;
  }
  .tech-card .idx {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--fg-3);
  }
  .tech-card .save {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--green);
    background: var(--green-soft);
    padding: 3px 10px; border-radius: 999px;
    font-weight: 600;
  }
  .tech-card h3 {
    font-size: 20px; font-weight: 700;
    color: var(--fg);
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }
  .tech-card p {
    font-size: 14.5px; color: var(--fg-2); line-height: 1.6;
  }

  /* ============== TIMELINE ============== */
  .timeline {
    border: 1px solid var(--rule);
    border-radius: 14px;
    background: var(--bg-2);
    overflow: hidden;
  }
  .tl-row {
    display: grid; grid-template-columns: 200px 1fr 180px;
    gap: 32px;
    padding: 36px 32px;
    border-bottom: 1px solid var(--rule);
    align-items: start;
  }
  .tl-row:last-child { border-bottom: none; }
  .tl-when {
    display: flex; align-items: center; gap: 12px;
  }
  .tl-when .dot {
    width: 30px; height: 30px;
    background: var(--accent-soft);
    border: 1px solid var(--accent);
    color: var(--accent-2);
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; font-weight: 700;
  }
  .tl-when .when {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11.5px; color: var(--fg-3);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .tl-body h3 {
    font-size: 22px; font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--fg);
    margin-bottom: 8px;
  }
  .tl-body p { font-size: 15px; color: var(--fg-2); line-height: 1.6; max-width: 60ch; }
  .tl-deliverable {
    background: var(--bg-3);
    border: 1px solid var(--rule);
    border-radius: 8px;
    padding: 14px;
    font-size: 12px;
    color: var(--fg-2);
    line-height: 1.5;
  }
  .tl-deliverable strong {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--accent-2);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 6px;
    font-weight: 600;
  }

  /* ============== NUMBERS ============== */
  .nums { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
  .num-card {
    background: var(--bg-2);
    border: 1px solid var(--rule);
    border-radius: 12px;
    padding: 28px;
  }
  .num-card .l {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--fg-3);
    letter-spacing: 0.06em; text-transform: uppercase;
  }
  .num-card .v {
    font-family: 'Inter', sans-serif;
    font-weight: 800;
    font-size: 56px;
    color: var(--fg);
    letter-spacing: -0.04em;
    line-height: 1;
    margin: 12px 0 6px;
    font-variant-numeric: tabular-nums;
  }
  .num-card .v em { font-family: 'Instrument Serif', serif; font-weight: 400; font-style: italic; color: var(--accent-2); }
  .num-card .v .u { font-size: 22px; color: var(--fg-3); margin-left: 2px; font-weight: 500; }
  .num-card .sub { font-size: 14px; color: var(--fg-2); line-height: 1.5; }

  /* ============== PRICING ============== */
  .price-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .plan {
    background: var(--bg-2);
    border: 1px solid var(--rule);
    border-radius: 14px;
    padding: 36px;
    position: relative;
  }
  .plan.featured { border-color: var(--accent); box-shadow: 0 0 0 1px var(--accent), 0 30px 60px -36px rgba(90,141,255,0.4); }
  .plan .tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--accent-2);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 12px;
    font-weight: 600;
  }
  .plan h3 {
    font-size: 28px; font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--fg);
    margin-bottom: 6px;
  }
  .plan .lead {
    font-size: 15px; color: var(--fg-2);
    margin-bottom: 24px;
    max-width: 38ch;
  }
  .plan .price {
    font-family: 'Inter', sans-serif;
    font-weight: 800;
    font-size: 48px;
    color: var(--fg);
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 6px;
    font-variant-numeric: tabular-nums;
  }
  .plan .price em { font-family: 'Instrument Serif', serif; font-weight: 400; font-style: italic; color: var(--accent-2); }
  .plan .price .u { font-size: 18px; color: var(--fg-2); font-weight: 500; }
  .plan .pn {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; color: var(--fg-3);
    margin-bottom: 24px;
  }
  .plan ul { list-style: none; padding: 0; margin-bottom: 24px; }
  .plan li {
    padding: 10px 0;
    border-top: 1px solid var(--rule);
    display: grid; grid-template-columns: 22px 1fr;
    gap: 12px;
    font-size: 14.5px;
    color: var(--fg);
    line-height: 1.5;
  }
  .plan li .ck {
    width: 18px; height: 18px;
    background: var(--accent-soft);
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    color: var(--accent-2); font-size: 11px;
    margin-top: 2px;
  }
  .plan .btn { width: 100%; justify-content: center; }

  /* ============== FAQ ============== */
  .faq-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 56px; }
  .faq-list details {
    border-bottom: 1px solid var(--rule);
    padding: 22px 0;
  }
  .faq-list details:first-child { border-top: 1px solid var(--rule); }
  .faq-list summary {
    list-style: none; cursor: pointer;
    display: flex; justify-content: space-between; align-items: center; gap: 16px;
    font-size: 18px; font-weight: 600;
    color: var(--fg);
    letter-spacing: -0.015em;
  }
  .faq-list summary::-webkit-details-marker { display: none; }
  .faq-list summary .icon {
    width: 22px; height: 22px;
    border-radius: 50%;
    background: var(--accent-soft);
    color: var(--accent-2);
    display: flex; align-items: center; justify-content: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    transition: transform .2s;
    flex-shrink: 0;
  }
  .faq-list details[open] summary .icon { transform: rotate(45deg); }
  .faq-list .a {
    padding-top: 14px;
    font-size: 16px; line-height: 1.65; color: var(--fg-2);
    max-width: 70ch;
  }
  .faq-list .a strong { color: var(--fg); font-weight: 600; }

  /* ============== RESOURCES ============== */
  .res { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .res-card {
    background: var(--bg-2);
    border: 1px solid var(--rule);
    border-radius: 12px;
    padding: 28px;
    color: var(--fg);
    transition: transform .15s, border-color .15s;
    display: block;
  }
  .res-card:hover { transform: translateY(-3px); border-color: var(--accent); color: var(--fg); }
  .res-card .row {
    display: flex; justify-content: space-between; align-items: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--accent-2);
    letter-spacing: 0.06em; text-transform: uppercase;
    margin-bottom: 24px;
    font-weight: 600;
  }
  .res-card h3 {
    font-size: 20px; font-weight: 700;
    color: var(--fg);
    letter-spacing: -0.02em;
    margin-bottom: 10px;
    line-height: 1.2;
  }
  .res-card p { font-size: 14px; color: var(--fg-2); line-height: 1.55; }
  .res-card .meta {
    margin-top: 22px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--fg-3);
    display: flex; justify-content: space-between;
  }

  /* ============== CTA ============== */
  .cta-band {
    padding: 120px 0;
    position: relative;
    overflow: hidden;
    border-top: 1px solid var(--rule);
  }
  .cta-band::before {
    content: "";
    position: absolute;
    top: 0; left: 50%;
    width: 1000px; height: 600px;
    transform: translateX(-50%);
    background: radial-gradient(ellipse at center, rgba(90,141,255,0.18) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }
  .cta-band .wrap { position: relative; z-index: 1; text-align: center; }
  .cta-band h2 {
    font-family: 'Inter', sans-serif;
    font-weight: 800;
    font-size: clamp(48px, 6vw, 88px);
    line-height: 1.0;
    letter-spacing: -0.045em;
    color: var(--fg);
    max-width: 18ch; margin: 16px auto 22px;
  }
  .cta-band h2 em { font-family: 'Instrument Serif', serif; font-style: italic; font-weight: 400; color: var(--accent-2); }
  .cta-band p {
    font-size: 18px; color: var(--fg-2);
    max-width: 56ch; margin: 0 auto 32px;
    line-height: 1.6;
  }
  .cta-band .row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .cta-band .fine {
    margin-top: 22px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--fg-3);
    letter-spacing: 0.06em;
  }

  /* ============== FOOTER ============== */
  footer.site { background: var(--bg-2); border-top: 1px solid var(--rule); padding: 64px 0 28px; }
  .foot-top {
    display: grid; grid-template-columns: 1.8fr repeat(4, 1fr);
    gap: 40px;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--rule);
  }
  footer.site h5 {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--fg-3);
    letter-spacing: 0.1em; text-transform: uppercase;
    margin-bottom: 16px;
    font-weight: 600;
  }
  footer.site ul { list-style: none; padding: 0; }
  footer.site li { padding: 5px 0; font-size: 14px; }
  footer.site li a { color: var(--fg-2); text-decoration: none; }
  footer.site li a:hover { color: var(--fg); }
  .foot-brand p {
    font-size: 14.5px; color: var(--fg-2); margin-top: 16px;
    max-width: 38ch; line-height: 1.6;
  }
  .foot-compliance {
    margin-top: 16px;
    display: flex; gap: 8px; flex-wrap: wrap;
  }
  .foot-compliance .c {
    background: var(--bg-3);
    border: 1px solid var(--rule);
    padding: 4px 10px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px; color: var(--fg-2);
    letter-spacing: 0.08em;
    border-radius: 4px;
  }
  .foot-bottom {
    padding-top: 24px;
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--fg-3);
    letter-spacing: 0.04em;
  }

  .langsw{display:inline-flex;gap:2px;font-family:'JetBrains Mono',ui-monospace,monospace;font-size:12px;margin-left:4px}.langsw a{color:inherit;opacity:.6;padding:4px 7px;border-radius:6px;text-decoration:none}.langsw a:hover{opacity:1}.langsw a[aria-current]{opacity:1;font-weight:600}

  @media (max-width: 1100px) {
    .cockpit-grid { grid-template-columns: 1fr; grid-template-rows: auto; }
    .ck-side, .ck-rail { grid-column: 1; grid-row: auto; border-right: none; border-left: none; border-bottom: 1px solid var(--rule); }
    .kpi-row { grid-template-columns: repeat(2, 1fr); }
    .pillars, .tech-grid, .nums, .price-grid, .res, .faq-grid, .sec-head, .foot-top { grid-template-columns: 1fr; }
    .nums, .tech-grid { grid-template-columns: 1fr 1fr; }
    .tl-row { grid-template-columns: 1fr; gap: 16px; }
    nav.primary { display: none; }
    section { padding: 64px 0; }
  }
</style>
<script src="/assets/consent.js" defer></script><script src="/assets/attribution.js" defer></script>
<script src="/assets/lang.js" defer></script>
</head>
