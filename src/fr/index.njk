      <div class="cockpit-bar">
        <div class="dots"><span class="dot"></span><span class="dot"></span><span class="dot"></span></div>
        <div class="url">app.finopsllm.com / customer-042 / overview</div>
        <span class="live"><span class="ld" aria-hidden="true"></span>DEMO</span>
      </div>
      <div class="cockpit-grid">

        <!-- LEFT SIDEBAR -->
        <aside class="ck-side" aria-label="Navigation de l'espace de travail">
          <h6>Espace de travail</h6>
          <div class="it active"><span class="i">◧</span>Aperçu</div>
          <div class="it"><span class="i">◫</span>Attribution<span class="b">12</span></div>
