          <h6>Finance</h6>
          <div class="it"><span class="i">$</span>Chargeback</div>
          <div class="it"><span class="i">▥</span>Budgets</div>
          <div class="it"><span class="i">✓</span>Réconciliation</div>
        </aside>

        <!-- MAIN -->
        <div class="ck-main">
          <div class="ck-tabs">
            <span class="ck-tab active">Aperçu</span>
            <span class="ck-tab">Dépenses</span>
            <span class="ck-tab">Qualité</span>
            <span class="ck-tab">Réconciliation</span>
          </div>

          <div class="kpi-row">
            <div class="kpi">
              <div class="l">Dépenses du mois à ce jour</div>
              <div class="v">$70 280</div>
              <div class="d">↓ 57,4% vs. ligne de base</div>
            </div>
            <div class="kpi">
              <div class="l">Économies d'exemple</div>
              <div class="v green">$94 720</div>
              <div class="d">réconciliées avec facture</div>
            </div>
            <div class="kpi">
              <div class="l">Taux de succès du cache</div>
              <div class="v">38.1%</div>
              <div class="d">+4,2 pts semaine/semaine</div>
            </div>
            <div class="kpi">
              <div class="l">Delta de qualité</div>
              <div class="v">+0,2%</div>
              <div class="d">Test A/B actif 7 jours</div>
            </div>
