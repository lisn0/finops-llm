<main id="main">{% endblock %}{% block body %}

<!-- HERO -->
<section class="hero" style="border-top: none;">
  <div class="wrap">
    <div class="hero-top">
      <span class="pill">
        <span class="v">FINOPS · LLM</span>
        <span>Basé sur les principes de la Fondation FinOps · adapté aux tokens</span>
      </span>
